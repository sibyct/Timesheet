# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4001
API_VERSION=v1
API_PREFIX=/api

# ─── MongoDB ─────────────────────────────────────────────────────────────────
# Local
MONGO_URI=mongodb://localhost:27017/timesheet_db
# Atlas (production)
# MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/timesheet_db?retryWrites=true&w=majority

MONGO_POOL_MAX=50
MONGO_POOL_MIN=10

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_SECONDS=300

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_access_super_secret_at_least_64_chars_long_xxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=CHANGE_ME_refresh_super_secret_at_least_64_chars_long_xxxxxxxxxxxxxxx
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── Logging ─────────────────────────────────────────────────────────────────
# trace | debug | info | warn | error | fatal
LOG_LEVEL=debug
